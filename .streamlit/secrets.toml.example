# ============================================================================
# Streamlit Secrets Configuration Template
# ============================================================================
# ВАЖЛИВО: Скопіюйте цей файл як .streamlit/secrets.toml
# та заповніть реальними даними. НЕ ДОДАВАЙТЕ secrets.toml до Git!
# ============================================================================

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ Supabase Configuration                                                   │
# └─────────────────────────────────────────────────────────────────────────┘
# Отримайте ці дані з вашого Supabase проєкту:
# Settings → API → Project URL and Project API keys

[supabase]
url = "https://your-project-id.supabase.co"
key = "your-anon-public-key-here"

# Приклад:
# url = "https://abcdefghijklmnop.supabase.co"
# key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZ..."


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ Admin Configuration                                                      │
# └─────────────────────────────────────────────────────────────────────────┘
# Пароль за замовчуванням: admin123
# Хеш пароля для безпеки (SHA256)

[admin]
password_hash = "240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9"

# Як змінити пароль:
# 1. Запустіть Python скрипт:
#    python -c "import hashlib; print(hashlib.sha256('your_password'.encode()).hexdigest())"
# 2. Замініть значення password_hash на отриманий результат

# Приклади хешів для різних паролів (НЕ ВИКОРИСТОВУЙТЕ ЦІ ПАРОЛІ В ПРОДАКШЕНІ!):
# admin123  → 240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9
# password  → 5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8
# drone2026 → a7f8f961e6f5c3b9d8e2c4a5b1d3e6f9a8c7b5d4e3f2a1b8c7d6e5f4a3b2c1d0


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ Optional: Future Configurations                                         │
# └─────────────────────────────────────────────────────────────────────────┘
# Додаткові налаштування для майбутніх функцій

# [parser]
# enabled = false
# api_url = "https://your-parser-service.com/api"
# api_key = "your-parser-api-key"
# sync_interval = 3600  # seconds

# [email]
# smtp_server = "smtp.gmail.com"
# smtp_port = 587
# sender_email = "noreply@example.com"
# sender_password = "your-app-password"

